# Copy this file to .env and fill in values from 1Password (Papercone vault)
# DO NOT commit .env — it is in .gitignore

# Backend
NODE_ENV=development
PORT=8000

# Database (if applicable)
DATABASE_URL=

# Impossible Cloud S3 (for feedback attachments)
S3_ENDPOINT=https://eu-central-2.storage.impossibleapi.net
S3_BUCKET_NAME=papercone-feedback-attachments
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=eu-central-2

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Frontend
VITE_API_URL=http://localhost:8000
